# Casper Agent Configuration
# Copy this file to .env and replace every placeholder below.

# Base URL of the deployed dashboard (scheme + host only).
# Do not add a trailing slash or /api — the client calls /api/feed and /api/guess on this host.
API_URL=https://your-dashboard-host.example.com

# Team API key used as Authorization: Bearer <token> (matches team.api_key in the dashboard database).
TEAM_TOKEN=your-team-api-key

# Google AI (Gemini) API key — https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-google-ai-api-key
